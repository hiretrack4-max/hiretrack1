# -----------------------------------------------------------------------------
# HireTrack environment configuration
# Copy this file to `.env` (in the backend/ directory) and adjust as needed.
# The defaults below match the bundled docker-compose PostgreSQL service.
# -----------------------------------------------------------------------------

# --- Django core ---
# Generate a new value for production, e.g. python -c "import secrets;print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-change-me-0123456789abcdef
DJANGO_DEBUG=True
# Comma separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Django timezone
DJANGO_TIME_ZONE=UTC
# Production only — comma-separated https origins for CSRF (deployed frontend/API):
#   DJANGO_CSRF_TRUSTED_ORIGINS=https://hiretrack.vercel.app,https://hiretrack-api.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Object storage for resume uploads (production) ---
# S3-compatible: Supabase Storage or Cloudflare R2. Leave STORAGE_BUCKET empty
# to store uploads on the local filesystem (dev). Supabase endpoint looks like
# https://<project-ref>.supabase.co/storage/v1/s3 and needs the project region.
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT_URL=
STORAGE_REGION=
# Neon (managed Postgres) requires SSL in production:
POSTGRES_SSLMODE=prefer

# --- PostgreSQL (matches docker-compose.yml service `db`) ---
POSTGRES_DB=hiretrack
POSTGRES_USER=hiretrack
POSTGRES_PASSWORD=hiretrack
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- CORS (React dev server, added in a later task) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Email (interview-scheduled HR notification, Module 10) ---
# By default the console backend just prints emails to the server log, so this
# works with NO credentials in dev. To actually send mail, switch EMAIL_BACKEND
# to SMTP and fill in the host/user/password below.
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=HireTrack <no-reply@hiretrack.local>
# Recipient of interview-scheduled notification emails (the single HR user).
HR_NOTIFY_EMAIL=avinash.selvan@skypointcloud.com

# --- Claude API (resume parsing — Modules 2 & 3) ---
# Leave ANTHROPIC_API_KEY empty to use the built-in regex/heuristic parser.
# Set it to enable Claude-powered extraction (auto-falls back to heuristic on error).
ANTHROPIC_API_KEY=
# Model used for resume parsing
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Set to False to store resume uploads without parsing them
RESUME_PARSING_ENABLED=True
# Wall-clock timeout (seconds) for the Claude call — keeps within the 10s budget
RESUME_PARSE_TIMEOUT=10
# Max tokens the extractor may generate
RESUME_PARSE_MAX_TOKENS=2048
